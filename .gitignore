__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ---- Configuracion local del usuario (incluye la clave de AcoustID) ----
.organizador_musica.json

# ---- Sistema operativo / editores ----
.DS_Store
Thumbs.db
.idea/
.vscode/
